{
  "name": "app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,green \"npm:dev:api\" \"npm:dev:web\"",
    "dev:web": "vite",
    "dev:api": "node --watch server/index.js",
    "build": "tsc -b && vite build",
    "start": "node server/index.js",
    "lint": "oxlint",
    "preview": "vite preview",
    "seed:15": "node test/seed-15.mjs",
    "test:calc": "node --test test/calc.test.ts",
    "test:game": "node --test test/game.test.ts",
    "test:db": "node --test test/db.pg.test.ts",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "express": "^5.2.1",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.3",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "oxlint": "^1.71.0",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
