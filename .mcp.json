{
  "mcpServers": {
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp"
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"],
      "env": {}
    },
    "lazyweb": {
      "type": "http",
      "url": "https://www.lazyweb.com/mcp",
      "headers": {
        "Authorization": "Bearer ${LAZYWEB_API_TOKEN}"
      }
    }
  }
}
